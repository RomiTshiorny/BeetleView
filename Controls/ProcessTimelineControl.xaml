<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="BeetleView.Controls.ProcessTimelineControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid Background="{ThemeResource SolidBackgroundFillColorBaseBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <!-- Status bar: render progress, truncation notice, etc. Kept out of
             the canvas itself so it never overlaps the time axis labels. -->
        <Border Grid.Row="0"
                x:Name="StatusBar"
                Visibility="Collapsed"
                Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                Padding="10,3">
            <TextBlock x:Name="StatusText"
                       FontSize="11"
                       Opacity="0.85"
                       TextTrimming="CharacterEllipsis" />
        </Border>
        <ScrollViewer Grid.Row="1"
                      x:Name="VScroll"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      ZoomMode="Disabled">
            <Canvas x:Name="DrawCanvas"
                    Background="Transparent"
                    HorizontalAlignment="Stretch">
                <!--
                    ZoomLayer holds the bars and exception ticks. It's
                    rendered ONCE at "session-full" scale (local x = time
                    proportionally mapped across timelineWidth) and then
                    zoomed via the CompositeTransform below — clearing and
                    re-creating thousands of XAML elements on every drag
                    was the source of the visible lag. ClipToBounds keeps
                    bars from spilling over the labels column when
                    zoomed-in.
                -->
                <Canvas x:Name="ZoomClip">
                    <Canvas x:Name="ZoomLayer">
                        <Canvas.RenderTransform>
                            <CompositeTransform x:Name="ZoomTransform"
                                                ScaleX="1"
                                                TranslateX="0" />
                        </Canvas.RenderTransform>
                    </Canvas>
                </Canvas>
            </Canvas>
        </ScrollViewer>
        <TextBlock x:Name="EmptyText"
                   Grid.Row="1"
                   Text="No session loaded."
                   Opacity="0.6"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Visibility="Visible" />
    </Grid>
</UserControl>

